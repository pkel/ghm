# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
build: [
  ["dune" "subst"] {pinned}
  ["dune" "build" "-p" name "-j" jobs]
  ["dune" "runtest" "-p" name "-j" jobs] {with-test}
  ["dune" "build" "-p" name "@doc"] {with-doc}
]
maintainer: ["Patrik Keller, <patrik@keller-re.de>"]
authors: ["Patrik Keller, <patrik@keller-re.de>"]
bug-reports: "https://github.com/n/a/issues"
homepage: "https://github.com/n/a"
license: "none"
dev-repo: "git+https://github.com/n/a.git"
synopsis: "Development Tools"
description: "Development Tools"
depends: [
  "ocamlformat" {< "0.14" & >= "0.13"}
  "odig" {> "0"}
  "merlin" {>= "3"}
  "ocp-indent" {> "0"}
  "odoc" {> "0"}
]
